{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "devCommand": "uvicorn cmd.main:app --reload --host 0.0.0.0 --port 8000",
  "functions": {
    "api/index.py": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
